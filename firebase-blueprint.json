{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with their domain and settings",
      "type": "object",
      "properties": {
        "userName": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "midnightLockEnabled": {
          "type": "boolean"
        },
        "themeMode": {
          "type": "string",
          "enum": ["light", "dark"]
        }
      },
      "required": ["userName", "domain"]
    },
    "AppUsage": {
      "title": "AppUsage",
      "description": "App usage data for the user",
      "type": "object",
      "properties": {
        "app": {
          "type": "string"
        },
        "timeInMinutes": {
          "type": "number"
        },
        "targetInMinutes": {
          "type": "number"
        },
        "iconName": {
          "type": "string"
        },
        "isStudyApp": {
          "type": "boolean"
        }
      },
      "required": ["app", "timeInMinutes", "targetInMinutes", "iconName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles. The document ID must match the authenticated user's ID."
    },
    "/users/{userId}/usage/{appId}": {
      "schema": {
        "$ref": "#/entities/AppUsage"
      },
      "description": "Stores the user's app usage targets and tracked times."
    }
  }
}
