rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isProfileOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation Helpers
    function isValidUserCreate(data) {
      return data.keys().hasAll(['userName', 'domain']) && 
             data.keys().size() >= 2 && data.keys().size() <= 4 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100 &&
             data.domain is string && data.domain.size() > 0 && data.domain.size() <= 100;
    }

    function isValidUserUpdate(data, currentData) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100 &&
             data.domain is string && data.domain.size() > 0 && data.domain.size() <= 100;
    }
    
    function isValidAppUsageCreate(data) {
      return data.keys().hasAll(['app', 'timeInMinutes', 'targetInMinutes', 'iconName']) &&
             data.app is string && data.app.size() > 0 && data.app.size() <= 100 &&
             data.timeInMinutes is number && data.timeInMinutes >= 0 &&
             data.targetInMinutes is number && data.targetInMinutes >= 0 &&
             data.iconName is string && data.iconName.size() > 0 && data.iconName.size() <= 100;
    }
    
    function isValidAppUsageUpdate(data, currentData) {
      return data.app is string && data.app.size() > 0 && data.app.size() <= 100 &&
             data.timeInMinutes is number && data.timeInMinutes >= 0 &&
             data.targetInMinutes is number && data.targetInMinutes >= 0 &&
             data.iconName is string && data.iconName.size() > 0 && data.iconName.size() <= 100;
    }

    match /users/{userId} {
      allow get: if isProfileOwner(userId);
      allow create: if isProfileOwner(userId) && isValidId(userId) && isValidUserCreate(incoming());
      allow update: if isProfileOwner(userId) && isValidId(userId) && isValidUserUpdate(incoming(), existing()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['userName', 'domain', 'midnightLockEnabled', 'themeMode'])
      );

      match /usage/{appId} {
        allow get: if isProfileOwner(userId);
        allow list: if isProfileOwner(userId);
        allow create: if isProfileOwner(userId) && isValidId(appId) && isValidAppUsageCreate(incoming());
        allow update: if isProfileOwner(userId) && isValidId(appId) && isValidAppUsageUpdate(incoming(), existing()) && (
           incoming().diff(existing()).affectedKeys().hasOnly(['timeInMinutes', 'targetInMinutes', 'isStudyApp', 'app', 'iconName'])
        );
      }
    }
  }
}
